# Database connection string
# PostgreSQL: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres/admin@localhost:5432/mydb

# Database type (postgres by default; mysql, sqlite is incomming)
DB_TYPE=postgres

# Migrations: auto-record each DDL change to migrations/ (set to false to disable)
MIGRATIONS_ENABLED=true

# Migrations directory (default: ./migrations relative to cwd)
# MIGRATIONS_DIR=/path/to/migrations
