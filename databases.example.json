/*
 * Database Configuration Example
 * Copy this file to databases.json and configure your connections
 *
 * Each database object supports:
 * - name: Unique identifier for the database
 * - description: Optional description of the database
 * - connectionString: Connection string (see notes per dbType below)
 * - dbType: Database type — "postgres" | "sqlite" | "mysql"
 * - enabled: Optional boolean, defaults to true. Set to false to disable
 * - readonly: Optional boolean, defaults to false. Set to true to block all write operations
 *
 * Connection string formats:
 *   postgres  → "postgresql://user:password@host:5432/dbname"
 *   mysql     → "mysql://user:password@host:3306/dbname"
 *   sqlite    → absolute file path, e.g. "/home/user/data/app.db"
 *               or ":memory:" for an in-memory database
 */
[
  {
    "name": "local",
    "description": "Local development database",
    "connectionString": "postgresql://user:password@localhost:5432/database_name",
    "dbType": "postgres",
    "enabled": true
  },
  {
    "name": "production",
    "description": "Production database - read-only for safety",
    "connectionString": "postgresql://user:password@prod-host:5432/database_name",
    "dbType": "postgres",
    "enabled": true,
    "readonly": true
  },
  {
    "name": "local_mysql",
    "description": "Local MySQL database",
    "connectionString": "mysql://user:password@localhost:3306/database_name",
    "dbType": "mysql",
    "enabled": false
  },
  {
    "name": "local_sqlite",
    "description": "Local SQLite file",
    "connectionString": "/absolute/path/to/your/database.db",
    "dbType": "sqlite",
    "enabled": false
  }
]
