{
  "name": "database-mcp",
  "version": "1.0.0",
  "description": "MCP server for database operations (PostgreSQL and extensible to others)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp databases.json dist/databases.json",
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:skills": "bash scripts/setup-skills.sh"
  },
  "keywords": [
    "mcp",
    "database",
    "postgresql"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.0",
    "mysql2": "^3.22.3",
    "odbc": "^2.5.0",
    "pg": "^8.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
